# Secrets & local state — never commit.
**/.env
**/.DS_Store
# Local SQLite DBs and the Fernet sealing key — under any product name, so a rename can't
# silently un-ignore an old one (this exact bug once swept a key into a commit).
**/*.db
**/*.db-wal
**/*.db-shm
**/.provekit.key
**/.agentman.key
**/*.key
**/venv/
**/.venv*/
**/node_modules/
**/.next/
**/*.tsbuildinfo
*.pyc
__pycache__/
*.egg-info/
.pytest_cache/
**/.coverage
**/htmlcov/

# isolated production-build output (keeps `next build` off the dev server's .next)
**/.next-build/

# python build artifacts
**/dist/
**/build/

# also ignore a node_modules symlink (dev convenience), not just the dir
node_modules

# Production secrets — never commit
deploy/provekit.online.env

# Next build dirs
frontend/.next-dev/
frontend/.next-build/

# stray bytecode from example scripts
examples/**/__pycache__/
