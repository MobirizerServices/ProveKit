# ProveKit reverse proxy. Set DOMAIN (e.g. provekit.example.com) — Caddy auto-provisions
# TLS via Let's Encrypt. /api and /v1 go to the backend; everything else to the frontend.
{$DOMAIN} {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Frame-Options "DENY"
	}

	@api path /api/* /v1/* /healthz
	reverse_proxy @api backend:8100

	reverse_proxy frontend:3001
}
