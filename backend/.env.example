# Copy to `.env` and fill in as needed. Local dev needs NOTHING here — ProveKit runs on
# sensible defaults (SQLite, no login). These matter for a hosted deployment.
#
# Never commit your real .env — it's git-ignored. Generate fresh secrets for each
# deployment; do not reuse another project's SECRET_KEY.

# --- database ---
# Local: SQLite (default). Hosted: a Postgres URL.
DATABASE_URL=sqlite:///./provekit.db

# --- mode ---
# Hosted mode = a login wall, secure cookies, strict SSRF guard on the outbound emit path,
# and a refusal to boot with a weak SECRET_KEY. Keep false for local single-user use.
HOSTED=false

# Signs session/reset/verify tokens (and derives local key material). Optional for local
# SQLite — a key file is auto-generated. REQUIRED for hosted mode (>=16 chars, not a dev
# default). Losing it just logs everyone out; no stored user secrets are lost. Generate:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# --- URLs ---
CORS_ORIGINS=http://localhost:3001,http://localhost:3000
WEB_BASE_URL=http://localhost:3001         # where the portal is served (used in emails)
PUBLIC_BASE_URL=http://localhost:8100       # where the API/ingest is reachable

# --- email (account verification / password reset) ---
# Without SMTP_HOST, verify/reset messages are NOT sent (signup still works). Configure a
# provider to enable them, then optionally require verification.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_STARTTLS=true
REQUIRE_EMAIL_VERIFICATION=false

# --- optional ---
SENTRY_DSN=                                 # error reporting (off when unset)
OTEL_EXPORT_URL=                            # mirror captured runs to another OTLP collector
THREAD_POOL_SIZE=200                        # max concurrent sync workers
