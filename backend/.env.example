# Copy to .env. All optional — AgentMan runs with sensible defaults.
DATABASE_URL=sqlite:///./agentman.db
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# Hosted mode: block outbound requests to private/internal IP ranges (SSRF).
# Keep false for local single-user use (localhost targets stay allowed).
HOSTED=false

# Encryption key for connection secrets at rest (api keys, auth headers).
# Optional for local SQLite — a key file (.agentman.key) is auto-generated next to
# the database. Required for any other database. Rotation: set the new value, then
# re-enter stored credentials.
SECRET_KEY=

# Seed example connections (OpenAI, Anthropic, Magari MCP + agent) on first run.
SEED_EXAMPLES=true
MAGARI_BACKEND_URL=http://127.0.0.1:8000
MAGARI_MCP_URL=http://127.0.0.1:8765/mcp

# Optional: prefill the example OpenAI connection's key.
OPENAI_API_KEY=
