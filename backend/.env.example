# Copy to .env. Optional for local use — ProveKit runs with sensible defaults.
# Hosted mode is stricter: it will not boot without a strong SECRET_KEY (see below).
DATABASE_URL=sqlite:///./provekit.db
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# Hosted mode. Turns on: strict SSRF guard (blocks private/internal IP ranges), a login
# wall, secure cookies, and a refusal to spawn local (stdio) MCP processes.
# Keep false for local single-user use (localhost targets and stdio stay allowed).
HOSTED=false

# Encryption key for connection secrets at rest (api keys, auth headers).
# Optional for local SQLite — a key file (.provekit.key) is auto-generated next to
# the database. Required for any other database. Rotation: set the new value, then
# re-enter stored credentials.
# HOSTED=true REFUSES TO BOOT unless this is >=16 chars and not a dev default:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Redis for paused flow-run (step-debug) contexts. Unset → in-memory, which only works
# single-process; required if you run more than one uvicorn worker.
REDIS_URL=

# Seed empty OpenAI + Anthropic example connections on first run. The keyless
# "Demo Assistant (mock)" connection is always seeded, regardless of this setting.
SEED_EXAMPLES=true

# Optional: prefill the example OpenAI connection's key.
OPENAI_API_KEY=

# Email (account recovery / verification). Without SMTP_HOST, reset/verify links are
# written to the logs instead of sent — fine for local/self-host.
WEB_BASE_URL=http://localhost:3001
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_STARTTLS=true
REQUIRE_EMAIL_VERIFICATION=false

# Flow deployments: the public URL where /v1/d/{slug} is reachable (shown in the UI),
# and a wall-clock cap per invocation in seconds (0 disables).
PUBLIC_BASE_URL=http://localhost:8100
DEPLOYMENT_TIMEOUT_S=120

# Optional: OTLP/HTTP collector to mirror ProveKit's own runs as gen_ai spans.
OTEL_EXPORT_URL=

# Optional: Sentry error reporting (off when unset).
SENTRY_DSN=

# Max concurrent sync workers; streams run in this threadpool.
THREAD_POOL_SIZE=200
