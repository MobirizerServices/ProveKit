{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": [
      "ES2022"
    ],
    "strict": true,
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "typeRoots": [
      "../../frontend/node_modules/@types",
      "./node_modules/@types"
    ]
  },
  "include": [
    "src/**/*.ts"
  ]
}