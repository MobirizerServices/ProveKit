# provekit.online production env — TEMPLATE. Copy to `provekit.online.env` (gitignored) and
# fill in the real secrets there. Consumed by compose.gateway.yml.
HOSTED=true
SECRET_KEY=generate-with:  python -c "import secrets;print(secrets.token_urlsafe(48))"
DATABASE_URL=postgresql+psycopg://provekit:CHANGE_ME_DB_PASSWORD@postgres:5432/provekit
WEB_BASE_URL=https://provekit.online
CORS_ORIGINS=https://provekit.online
MAX_BODY_BYTES=25000000
REDIS_URL=redis://redis:6379/0
SUPERUSER_EMAILS=info@provekit.online

# Transactional email (Titan via BigRock). Use port 587 + STARTTLS (the mailer uses STARTTLS,
# NOT implicit-SSL 465). The password is in the real env file only, never here.
SMTP_HOST=smtp.titan.email
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_USER=info@provekit.online
SMTP_PASSWORD=__from_bigrock_titan_panel__
SMTP_FROM=Provekit <info@provekit.online>

# Frontend
NEXT_PUBLIC_SITE_URL=https://provekit.online
