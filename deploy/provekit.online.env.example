# provekit.online production env — TEMPLATE. Copy to `provekit.online.env` (gitignored) and
# fill in real secrets there. Works for BOTH deploy paths:
#   • compose.prod.yml  (ProveKit's own Caddy on 80/443 — the toggle setup) → --env-file
#   • compose.gateway.yml / compose.contabo.yml → env_file
HOSTED=true
DOMAIN=provekit.online
SECRET_KEY=generate-with:  python -c "import secrets;print(secrets.token_urlsafe(48))"

# Postgres. POSTGRES_PASSWORD is what compose.prod.yml passes to the db container; keep it in
# sync with the password inside DATABASE_URL (used by the gateway/contabo composes).
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
DATABASE_URL=postgresql+psycopg://provekit:CHANGE_ME_DB_PASSWORD@postgres:5432/provekit

WEB_BASE_URL=https://provekit.online
CORS_ORIGINS=https://provekit.online
MAX_BODY_BYTES=25000000
SUPERUSER_EMAILS=info@provekit.online

# Transactional email (Titan via BigRock). Use 587 + STARTTLS (the mailer uses STARTTLS, not
# implicit-SSL 465). Password lives in the real env file only, never here.
SMTP_HOST=smtp.titan.email
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_USER=info@provekit.online
SMTP_PASSWORD=__from_bigrock_titan_panel__
SMTP_FROM=Provekit <info@provekit.online>

# Frontend
NEXT_PUBLIC_SITE_URL=https://provekit.online
