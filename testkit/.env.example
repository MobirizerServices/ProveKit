# Copy this file to `.env` and fill in your values.
#   cp .env.example .env

# A project key from your portal → Project keys → Create key (shown once).
PROVEKIT_API_KEY=pk_your_key_here

# Your ProveKit portal URL.
PROVEKIT_ENDPOINT=https://provekit.online

# Optional — set a real model key and the LangGraph demos use gpt-4o-mini
# instead of the offline canned model.
# OPENAI_API_KEY=sk-...
